# ================================================================
# j_ai_trade — environment template
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# ================================================================

# ---- Runtime -----------------------------------------------------
ENV=DEV

# ---- Telegram (advisor chat bot) --------------------------------
# Separate bot from the cron one. Create via @BotFather -> /newbot.
# Phase 1: the backend long-polls this bot and replies conversationally.
J_AI_TRADE_ADVISOR=
J_AI_TRADE_ADVISOR_DEV=

# Optional: comma-separated Telegram user IDs allowed to chat with
# the advisor bot. Leave unset to allow everyone (risky in prod, fine
# for local dev). Find your user ID by DMing @userinfobot.
ADVISOR_ALLOWED_USER_IDS=

#Firebase service account
SERVICE_ACCOUNT_FIREBASE_BASE_64=

# ---- AI provider ------------------------------------------------
# Switch between providers by changing AI_PROVIDER. Only the key for
# the active provider needs to be filled in.
#
# "deep-seek" (default) — get key from https://platform.deepseek.com
# "claude"              — get key from https://console.anthropic.com
AI_PROVIDER=deep-seek

DEEP_SEEK_API_KEY=
DEEP_SEEK_BASE_URL=                  # optional; defaults to https://api.deepseek.com
DEEP_SEEK_MODEL=                     # optional; defaults to deepseek-chat

CLAUDE_API_KEY=
CLAUDE_BASE_URL=                     # optional; defaults to https://api.anthropic.com
CLAUDE_MODEL=                        # optional; defaults to claude-sonnet-4-6
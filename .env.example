# ================================================================
# j_ai_trade — environment template
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# ================================================================

# ---- Runtime -----------------------------------------------------
ENV=DEV

# ---- Telegram (advisor chat bot) --------------------------------
# Separate bot from the cron one. Create via @BotFather -> /newbot.
# Phase 1: the backend long-polls this bot and replies conversationally.
J_AI_TRADE_ADVISOR=
J_AI_TRADE_ADVISOR_DEV=

# Optional: comma-separated Telegram user IDs allowed to chat with
# the advisor bot. Leave unset to allow everyone (risky in prod, fine
# for local dev). Find your user ID by DMing @userinfobot.
ADVISOR_ALLOWED_USER_IDS=

#Firebase service account
SERVICE_ACCOUNT_FIREBASE_BASE_64=

# ---- DeepSeek ---------------------------------------------------
# API key held ONLY by the backend. Never sent to Telegram/frontend.
# Get from https://platform.deepseek.com -> API Keys.
DEEP_SEEK_API_KEY=
LLM_API_KEY=

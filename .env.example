# ================================================================
# j_ai_trade — environment template
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# ================================================================

# ---- Runtime -----------------------------------------------------
ENV=DEV

# ---- Database (Postgres) ----------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=j_ai_trade
DB_SSLMODE=disable

# ---- Redis -------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Telegram (cron signal bot) ---------------------------------
# Used by cron_jobs to broadcast ensemble signals to a fixed channel.
J_AI_TRADE_BOT_V1=
J_AI_TRADE_BOT_V1_CHAN=

# ---- Telegram (advisor chat bot) --------------------------------
# Separate bot from the cron one. Create via @BotFather -> /newbot.
# Phase 1: the backend long-polls this bot and replies conversationally.
J_AI_TRADE_ADVISOR=

# Optional: comma-separated Telegram user IDs allowed to chat with
# the advisor bot. Leave unset to allow everyone (risky in prod, fine
# for local dev). Find your user ID by DMing @userinfobot.
ADVISOR_ALLOWED_USER_IDS=

# ---- DeepSeek ---------------------------------------------------
# API key held ONLY by the backend. Never sent to Telegram/frontend.
# Get from https://platform.deepseek.com -> API Keys.
DEEP_SEEK_API_KEY=

# Override only if you're using a proxy/compat endpoint.
# DEEP_SEEK_BASE_URL=https://api.deepseek.com

# Model options:
#   deepseek-chat      — fast, cheap, good for conversational Phase 1 (default)
#   deepseek-reasoner  — deeper reasoning, slower & pricier; better for Phase 2 signal generation
# DEEP_SEEK_MODEL=deepseek-chat

# ---- JWT --------------------------------------------------------
JWT_SECRET=
